# Define tax scenarios (USD per tCO2)
tax_scenarios = {
    'Low Tax': 25,
    'Medium Tax': 50,
    'High Tax': 75,
    'Very High Tax': 100
}

# Current baseline
current_avg_price = df['Carbon_Price_USD_per_t'].mean()
print(f"\nCurrent average carbon price: ${current_avg_price:.2f}/tCO2")

# Calculate emissions and gaps
total_emissions = df['Emission_Produced_tCO2'].sum()
total_allowances = df['Emission_Allowance_tCO2'].sum()
total_gap = df['Allowance_Gap_tCO2'].sum()

print(f"\nTotal emissions: {total_emissions:,.0f} tCO2")
print(f"Total allowances: {total_allowances:,.0f} tCO2")
print(f"Net allowance gap: {total_gap:,.0f} tCO2")

print("\n" + "-"*50)
print("TAX SCENARIO SIMULATIONS")
print("-"*50)

results = []

for scenario_name, tax_rate in tax_scenarios.items():
    print(f"\n{scenario_name} (${tax_rate}/tCO2):")

    # Calculate tax impacts
    df[f'Tax_Cost_{scenario_name.replace(" ", "_")}'] = df['Emission_Produced_tCO2'] * tax_rate

    # Scenario metrics
    total_tax = df[f'Tax_Cost_{scenario_name.replace(" ", "_")}'].sum()
    avg_tax_per_company = df[f'Tax_Cost_{scenario_name.replace(" ", "_")}'].mean()

    # Impact on companies with deficit vs surplus
    deficit_companies = df[df['Allowance_Gap_tCO2'] > 0]
    surplus_companies = df[df['Allowance_Gap_tCO2'] < 0]

    deficit_tax = (deficit_companies['Emission_Produced_tCO2'] * tax_rate).sum()
    surplus_tax = (surplus_companies['Emission_Produced_tCO2'] * tax_rate).sum()

    # Tax as percentage of compliance cost
    avg_compliance_cost = df['Compliance_Cost_USD'].mean()
    tax_vs_compliance = (avg_tax_per_company / avg_compliance_cost) * 100

    print(f"  Total tax revenue: ${total_tax:,.0f}")
    print(f"  Average tax per company: ${avg_tax_per_company:,.0f}")
    print(f"  Tax from deficit companies: ${deficit_tax:,.0f}")
    print(f"  Tax from surplus companies: ${surplus_tax:,.0f}")
    print(f"  Tax as % of compliance cost: {tax_vs_compliance:.1f}%")

    # Store results
    results.append({
        'Scenario': scenario_name,
        'Tax_Rate': tax_rate,
        'Total_Revenue': total_tax,
        'Avg_Tax_Per_Company': avg_tax_per_company,
        'Deficit_Companies_Tax': deficit_tax,
        'Surplus_Companies_Tax': surplus_tax,
        'Tax_vs_Compliance_Pct': tax_vs_compliance
    })

# Summary table
print("\n" + "="*50)
