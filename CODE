import pandas as pd
import numpy as np
from sklearn.decomposition import FastICA
from sklearn.preprocessing import StandardScaler

# Select numerical columns for ICA
numerical_cols = ['Energy_Demand_MWh', 'Emission_Produced_tCO2', 'Emission_Allowance_tCO2',
                  'Carbon_Price_USD_per_t', 'Credits_Traded_tCO2', 'Compliance_Cost_USD',
                  'Carbon_Cost_Savings_USD', 'Target_Trade_Action']

# Prepare data
X = df[numerical_cols].copy()

# Standardize the data
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

# Perform ICA with 3 components
ica = FastICA(n_components=3, random_state=42, max_iter=1000)
X_ica = ica.fit_transform(X_scaled)

# Get the mixing matrix and independent components
mixing_matrix = ica.mixing_
ic_components = ica.components_

print("="*50)
print("INDEPENDENT COMPONENT ANALYSIS (ICA)")
print("="*50)

print(f"\nICA with 3 components completed")
print(f"Original data shape: {X_scaled.shape}")
print(f"ICA transformed shape: {X_ica.shape}")

print("\n" + "-"*50)
print("INDEPENDENT COMPONENTS (Loadings):")
print("-"*50)
ic_df = pd.DataFrame(ic_components.T,
                     columns=['IC1', 'IC2', 'IC3'],
                     index=numerical_cols)
print(ic_df.round(4))

print("\n" + "-"*50)
print("MIXING MATRIX:")
print("-"*50)
mixing_df = pd.DataFrame(mixing_matrix,
                         columns=['IC1', 'IC2', 'IC3'],
                         index=numerical_cols)
print(mixing_df.round(4))

print("\n" + "-"*50)
print("ICA TRANSFORMED DATA (First 10 rows):")
print("-"*50)
ica_df = pd.DataFrame(X_ica, columns=['IC1', 'IC2', 'IC3'])
print(ica_df.head(10))

# Show which variables contribute most to each IC
print("\n" + "-"*50)
print("TOP CONTRIBUTORS TO EACH IC:")
print("-"*50)

for i in range(3):
    ic_col = f'IC{i+1}'
    abs_loadings = abs(ic_df[ic_col])
    top_vars = abs_loadings.nlargest(3)
    print(f"\n{ic_col} - Top 3 variables:")
    for var, val in top_vars.items():
        sign = "+" if ic_df.loc[var, ic_col] > 0 else "-"
        print(f"  {var}: {sign}{abs(val):.4f}")

# Get the 3 IC curves (the independent components themselves)
print("\n" + "-"*50)
print("THE 3 INDEPENDENT COMPONENT CURVES:")
print("-"*50)
print("\nIC1 curve (first 20 values):")
print(ica_df['IC1'].head(20).values)

print("\nIC2 curve (first 20 values):")
print(ica_df['IC2'].head(20).values)

print("\nIC3 curve (first 20 values):")
print(ica_df['IC3'].head(20).values)

# Summary statistics of the IC curves
print("\n" + "-"*50)
print("IC CURVES SUMMARY STATISTICS:")
print("-"*50)
print(ica_df.describe().round(4))

# Add ICs to original dataframe if needed
df_with_ic = df.copy()
df_with_ic['IC1'] = X_ica[:, 0]
df_with_ic['IC2'] = X_ica[:, 1]
df_with_ic['IC3'] = X_ica[:, 2]

print("\n" + "-"*50)
print("IC CURVES SAVED TO DATAFRAME")
print("-"*50)
print("Available as: df_with_ic['IC1'], df_with_ic['IC2'], df_with_ic['IC3']")

